# محلياً: اتركها فارغة ليستخدم النظام قاعدة بيانات SQLite محلية (dev.db)
# في الإنتاج: أنشئ قاعدة بيانات مجانية على https://turso.tech وضع بياناتها هنا
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# سر التشفير الخاص بالجلسات - ولّده بالأمر: npx auth secret
AUTH_SECRET=

# بيانات حساب الشيخ الرئيسي الافتراضي (يُستخدم مرة واحدة عند تشغيل سكربت seed)
SEED_ADMIN_NAME=الشيخ المشرف
SEED_ADMIN_EMAIL=admin@ghofran.local
SEED_ADMIN_PASSWORD=ChangeMe123!
